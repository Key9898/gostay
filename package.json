    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.2",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.23.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.1",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.17",
